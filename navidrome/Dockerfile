# syntax=docker/dockerfile:1.7

# =========================================================
# JBS Networks Navidrome Ultra 6.1 Slim v10.1 Stable Final
# AMD EPYC Zen3 Dedicated Edition
#
# Updated 2026-07-12:
#   - Go 1.26.5
#   - Node.js 26.5.0
#   - Rust 1.97.0
#   - FFmpeg 8.1.2
#   - jemalloc 5.3.1
#   - Opus 1.6.1
#   - LAME 3.100 (FFmpeg 8.1.x stable compatibility)
#   - TagLib 2.3
#   - rusqlite 0.40.1
#
# Main fixes:
#   - Correct FFmpeg fallback preflight checks
#   - Make SQLite doctor validate returned rows
#   - Stop silently ignoring SQLite open failures
#   - Add cgroup v1/v2 CPU and memory detection
#   - Cap CPU quota by cpuset/nproc
#   - Avoid GOMEMLIMIT minimum exceeding tiny containers
#   - Verify /data, /cache and /music runtime paths
#   - Remove risky SQLITE_USE_ALLOCA
#   - Reduce per-connection SQLite memory for light servers
#   - Validate FFmpeg capabilities at image build time
# =========================================================

ARG DEBIAN_IMAGE=debian:trixie-slim@sha256:28de0877c2189802884ccd20f15ee41c203573bd87bb6b883f5f46362d24c5c2
ARG NODE_IMAGE=node:26.5.0-trixie-slim@sha256:ffc78385a788964bb3cbab5e434ff79a10bdc25b8ae6db03fe5fe6cb14053c09
ARG GOLANG_IMAGE=golang:1.26.5-trixie@sha256:116489021a0d8ca3facf79f84ee69052cff88733547150a644d45c5eaa91dc43
ARG RUST_IMAGE=rust:1.97.0-slim-trixie@sha256:14c4fe50ea427dc42381a1a09a9a839c1d2346a2e508cd491bf02c659dbc0ed7

ARG NAVIDROME_REPOSITORY=https://github.com/TAE-OK-11/navidrome.git
ARG NAVIDROME_REF=master
ARG NAVIDROME_CACHEBUST=20260712-v10.1

ARG JEMALLOC_VERSION=5.3.1
ARG FFMPEG_VERSION=8.1.2
ARG OPUS_VERSION=1.6.1
ARG LAME_VERSION=3.100
ARG TAGLIB_VERSION=2.3
ARG RUSQLITE_VERSION=0.40.1
ARG WALKDIR_VERSION=2.5.0

ARG NAVIDROME_BUILD_CORES=4
ARG FFMPEG_THREADS=auto
ARG GOMEMLIMIT=auto
ARG GOMAXPROCS=auto
ARG GOGC=125
ARG SCANSCHEDULE=0
ARG GOAMD64_VERSION=v3
ARG RUST_TARGET_CPU=znver3

ARG JBS_GOMAXPROCS_MAX=4
ARG JBS_FFMPEG_THREADS_MAX=2
ARG JBS_GOMEMLIMIT_PERCENT=55
ARG JBS_GOMEMLIMIT_MIN_MIB=192
ARG JBS_GOMEMLIMIT_MAX_MIB=4096

ARG CPU_OPTIMIZATION_FLAGS="-O3 -march=znver3 -mtune=znver3 -DNDEBUG -ffunction-sections -fdata-sections -pipe -fno-plt"
ARG THIN_LTO_FLAGS="-flto=thin"
ARG FULL_LTO_FLAGS="-flto"
ARG SQLITE_LTO_FLAGS="-flto=thin"
ARG TAGLIB_LTO_FLAGS="-flto=thin"
ARG LLD_FLAGS="-fuse-ld=lld -Wl,-O2 -Wl,--gc-sections -Wl,--icf=safe -Wl,--as-needed -Wl,-z,relro,-z,now -Wl,--build-id=none"

ARG SQLITE_EXTRA_CFLAGS="\
-DSQLITE_ENABLE_FTS5 \
-DSQLITE_ENABLE_STAT4 \
-DSQLITE_OMIT_SHARED_CACHE \
-DSQLITE_DEFAULT_WAL_AUTOCHECKPOINT=4096 \
-DSQLITE_DEFAULT_WAL_SYNCHRONOUS=1 \
-DSQLITE_TEMP_STORE=2 \
-DSQLITE_DEFAULT_MMAP_SIZE=134217728 \
-DSQLITE_MAX_MMAP_SIZE=536870912 \
-DSQLITE_DEFAULT_CACHE_SIZE=-32768 \
-DSQLITE_DEFAULT_MEMSTATUS=0 \
-DSQLITE_LIKE_DOESNT_MATCH_BLOBS"

ARG JEMALLOC_SHA256=3826bc80232f22ed5c4662f3034f799ca316e819103bdc7bb99018a421706f92
ARG FFMPEG_SHA256=464beb5e7bf0c311e68b45ae2f04e9cc2af88851abb4082231742a74d97b524c
ARG OPUS_SHA256=6ffcb593207be92584df15b32466ed64bbec99109f007c82205f0194572411a1
ARG LAME_SHA256=ddfe36cab873794038ae2c1210557ad34857a4b6bdc515785d1da9e175b1da1e
ARG TAGLIB_SHA256=7349f6fd942418bc7009ebe743eb7c9d055f02921ec56fa436ec25007c47fd38

# =========================================================
# Source
# =========================================================

FROM ${DEBIAN_IMAGE} AS source

ARG NAVIDROME_REF
ARG NAVIDROME_REPOSITORY
ARG NAVIDROME_CACHEBUST

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      git

WORKDIR /src

RUN echo "NAVIDROME_CACHEBUST=${NAVIDROME_CACHEBUST}" >/dev/null && \
    git init . && \
    git remote add origin "${NAVIDROME_REPOSITORY}" && \
    if git ls-remote --exit-code --heads origin "${NAVIDROME_REF}" >/dev/null 2>&1; then \
      git fetch --depth=1 origin "refs/heads/${NAVIDROME_REF}"; \
    elif git ls-remote --exit-code --tags origin "${NAVIDROME_REF}" >/dev/null 2>&1; then \
      git fetch --depth=1 origin "refs/tags/${NAVIDROME_REF}"; \
    else \
      git fetch --depth=1 origin "${NAVIDROME_REF}"; \
    fi && \
    git checkout --detach FETCH_HEAD && \
    git rev-parse --short=12 HEAD > /src/.git_sha && \
    git show -s --format=%ct HEAD > /src/.git_epoch && \
    rm -rf .git

# =========================================================
# jemalloc
# =========================================================

FROM ${DEBIAN_IMAGE} AS jemalloc-builder

ARG JEMALLOC_VERSION
ARG JEMALLOC_SHA256
ARG NAVIDROME_BUILD_CORES
ARG CPU_OPTIMIZATION_FLAGS
ARG THIN_LTO_FLAGS
ARG LLD_FLAGS

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      autoconf \
      automake \
      build-essential \
      bzip2 \
      ca-certificates \
      clang \
      libtool \
      lld \
      llvm \
      wget

WORKDIR /build

RUN wget --https-only --tries=3 --max-redirect=3 -qO jemalloc.tar.bz2 \
      "https://github.com/jemalloc/jemalloc/releases/download/${JEMALLOC_VERSION}/jemalloc-${JEMALLOC_VERSION}.tar.bz2" && \
    echo "${JEMALLOC_SHA256}  jemalloc.tar.bz2" | sha256sum -c - && \
    tar -tjf jemalloc.tar.bz2 >/dev/null && \
    mkdir jemalloc && \
    tar -xjf jemalloc.tar.bz2 --strip-components=1 -C jemalloc

WORKDIR /build/jemalloc

RUN CC="clang -fuse-ld=lld" \
    CXX="clang++ -fuse-ld=lld" \
    AR=llvm-ar \
    RANLIB=llvm-ranlib \
    NM=llvm-nm \
    STRIP=llvm-strip \
    CFLAGS="${CPU_OPTIMIZATION_FLAGS} ${THIN_LTO_FLAGS}" \
    CXXFLAGS="${CPU_OPTIMIZATION_FLAGS} ${THIN_LTO_FLAGS}" \
    LDFLAGS="${THIN_LTO_FLAGS} ${LLD_FLAGS}" \
    ./configure \
      --prefix=/usr/local \
      --disable-cxx \
      --disable-stats \
      --with-malloc-conf="background_thread:true,metadata_thp:disabled,narenas:2,dirty_decay_ms:5000,muzzy_decay_ms:10000,oversize_threshold:8388608,retain:false" && \
    make -j"${NAVIDROME_BUILD_CORES}" install && \
    find /usr/local/lib -name "libjemalloc.so.*" ! -type l \
      -exec llvm-strip --strip-unneeded {} +

# =========================================================
# libopus static
# =========================================================

FROM ${DEBIAN_IMAGE} AS opus-builder

ARG OPUS_VERSION
ARG OPUS_SHA256
ARG NAVIDROME_BUILD_CORES
ARG CPU_OPTIMIZATION_FLAGS
ARG FULL_LTO_FLAGS
ARG LLD_FLAGS

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      autoconf \
      automake \
      build-essential \
      ca-certificates \
      clang \
      libtool \
      lld \
      llvm \
      pkg-config \
      wget

WORKDIR /build

RUN wget --https-only --tries=3 --max-redirect=3 -qO opus.tar.gz \
      "https://downloads.xiph.org/releases/opus/opus-${OPUS_VERSION}.tar.gz" && \
    echo "${OPUS_SHA256}  opus.tar.gz" | sha256sum -c - && \
    tar -tzf opus.tar.gz >/dev/null && \
    mkdir opus && \
    tar -xzf opus.tar.gz --strip-components=1 -C opus

WORKDIR /build/opus

RUN CC="clang -fuse-ld=lld" \
    CXX="clang++ -fuse-ld=lld" \
    AR=llvm-ar \
    RANLIB=llvm-ranlib \
    NM=llvm-nm \
    STRIP=llvm-strip \
    CFLAGS="${CPU_OPTIMIZATION_FLAGS} ${FULL_LTO_FLAGS}" \
    CXXFLAGS="${CPU_OPTIMIZATION_FLAGS} ${FULL_LTO_FLAGS}" \
    LDFLAGS="${FULL_LTO_FLAGS} ${LLD_FLAGS}" \
    ./configure \
      --prefix=/usr/local \
      --disable-shared \
      --enable-static \
      --disable-extra-programs \
      --disable-doc && \
    make -j"${NAVIDROME_BUILD_CORES}" install && \
    llvm-ranlib /usr/local/lib/libopus.a

# =========================================================
# LAME MP3 encoder static
# Stable compatibility choice for FFmpeg 8.1.x
# =========================================================

FROM ${DEBIAN_IMAGE} AS lame-builder

ARG LAME_VERSION
ARG LAME_SHA256
ARG NAVIDROME_BUILD_CORES
ARG CPU_OPTIMIZATION_FLAGS
ARG FULL_LTO_FLAGS
ARG LLD_FLAGS

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      autoconf \
      automake \
      build-essential \
      ca-certificates \
      clang \
      libtool \
      lld \
      llvm \
      nasm \
      pkg-config \
      wget

WORKDIR /build

RUN wget --https-only --tries=3 --max-redirect=3 -qO lame.tar.gz \
      "https://downloads.sourceforge.net/project/lame/lame/${LAME_VERSION}/lame-${LAME_VERSION}.tar.gz" && \
    echo "${LAME_SHA256}  lame.tar.gz" | sha256sum -c - && \
    tar -tzf lame.tar.gz >/dev/null && \
    mkdir lame && \
    tar -xzf lame.tar.gz --strip-components=1 -C lame

WORKDIR /build/lame

RUN CC=clang \
    CXX=clang++ \
    AR=llvm-ar \
    RANLIB=llvm-ranlib \
    NM=llvm-nm \
    STRIP=llvm-strip \
    CFLAGS="${CPU_OPTIMIZATION_FLAGS} ${FULL_LTO_FLAGS}" \
    CXXFLAGS="${CPU_OPTIMIZATION_FLAGS} ${FULL_LTO_FLAGS}" \
    LDFLAGS="${FULL_LTO_FLAGS} ${LLD_FLAGS}" \
    ./configure \
      --prefix=/usr/local \
      --disable-shared \
      --enable-static \
      --disable-dependency-tracking \
      --disable-rpath \
      --enable-nasm \
      --disable-frontend \
      --disable-decoder \
      --disable-analyzer-hooks

RUN make -j"${NAVIDROME_BUILD_CORES}" V=1 && \
    make install && \
    test -s /usr/local/lib/libmp3lame.a && \
    test -s /usr/local/include/lame/lame.h && \
    llvm-ranlib /usr/local/lib/libmp3lame.a

RUN mkdir -p /usr/local/lib/pkgconfig && \
    printf '%s\n' \
      'prefix=/usr/local' \
      'exec_prefix=${prefix}' \
      'libdir=${exec_prefix}/lib' \
      'includedir=${prefix}/include' \
      '' \
      'Name: libmp3lame' \
      'Description: LAME MP3 encoder library' \
      "Version: ${LAME_VERSION}" \
      'Libs: -L${libdir} -lmp3lame' \
      'Libs.private: -lm' \
      'Cflags: -I${includedir}' \
      > /usr/local/lib/pkgconfig/libmp3lame.pc && \
    PKG_CONFIG_PATH=/usr/local/lib/pkgconfig \
      pkg-config --modversion libmp3lame && \
    PKG_CONFIG_PATH=/usr/local/lib/pkgconfig \
      pkg-config --libs --static libmp3lame

# =========================================================
# FFmpeg: audio-focused Opus / MP3 / AAC / FLAC
# =========================================================

FROM ${DEBIAN_IMAGE} AS ffmpeg-builder

ARG FFMPEG_VERSION
ARG FFMPEG_SHA256
ARG NAVIDROME_BUILD_CORES
ARG CPU_OPTIMIZATION_FLAGS
ARG FULL_LTO_FLAGS
ARG LLD_FLAGS

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      build-essential \
      ca-certificates \
      clang \
      file \
      lld \
      llvm \
      nasm \
      pkg-config \
      wget \
      xz-utils \
      yasm

COPY --from=opus-builder /usr/local/lib/libopus.a /usr/local/lib/
COPY --from=opus-builder /usr/local/lib/pkgconfig/opus.pc /usr/local/lib/pkgconfig/
COPY --from=opus-builder /usr/local/include/opus /usr/local/include/opus

COPY --from=lame-builder /usr/local/lib/libmp3lame.a /usr/local/lib/
COPY --from=lame-builder /usr/local/lib/pkgconfig/libmp3lame.pc /usr/local/lib/pkgconfig/
COPY --from=lame-builder /usr/local/include/lame /usr/local/include/lame

ENV PKG_CONFIG_PATH=/usr/local/lib/pkgconfig:/usr/lib/pkgconfig:/usr/share/pkgconfig

RUN pkg-config --modversion opus && \
    pkg-config --modversion libmp3lame && \
    pkg-config --libs --static opus && \
    pkg-config --libs --static libmp3lame && \
    test -s /usr/local/include/lame/lame.h && \
    test -s /usr/local/lib/libopus.a && \
    test -s /usr/local/lib/libmp3lame.a

WORKDIR /build

RUN wget --https-only --tries=3 --max-redirect=3 -qO ffmpeg.tar.xz \
      "https://ffmpeg.org/releases/ffmpeg-${FFMPEG_VERSION}.tar.xz" && \
    echo "${FFMPEG_SHA256}  ffmpeg.tar.xz" | sha256sum -c - && \
    tar -tJf ffmpeg.tar.xz >/dev/null && \
    mkdir ffmpeg && \
    tar -xJf ffmpeg.tar.xz --strip-components=1 -C ffmpeg

WORKDIR /build/ffmpeg

RUN set -eu; \
    if ! ./configure \
      --prefix=/usr/local \
      --cc=clang \
      --cxx=clang++ \
      --ar=llvm-ar \
      --ranlib=llvm-ranlib \
      --nm=llvm-nm \
      --strip=llvm-strip \
      --pkg-config=pkg-config \
      --pkg-config-flags=--static \
      --target-os=linux \
      --arch=x86_64 \
      --cpu=znver3 \
      --disable-runtime-cpudetect \
      --enable-hardcoded-tables \
      --disable-autodetect \
      --disable-network \
      --disable-debug \
      --disable-doc \
      --disable-ffplay \
      --enable-ffprobe \
      --disable-everything \
      --enable-static \
      --disable-shared \
      --extra-cflags="-I/usr/local/include ${CPU_OPTIMIZATION_FLAGS} ${FULL_LTO_FLAGS}" \
      --extra-ldflags="-L/usr/local/lib ${FULL_LTO_FLAGS} ${LLD_FLAGS}" \
      --extra-libs="-lm" \
      --enable-avcodec \
      --enable-avformat \
      --enable-avfilter \
      --enable-swresample \
      --enable-protocol=file,pipe \
      --enable-demuxer=mov,mp3,aac,flac,wav,aiff,ogg,ape,matroska,wv,s16le \
      --enable-decoder=alac,aac,mp3,mp3float,flac,opus,vorbis,ape,wavpack,pcm_s16le,pcm_s16be,pcm_s24le,pcm_s24be,pcm_s32le,pcm_f32le \
      --enable-parser=aac,mpegaudio,flac,opus \
      --enable-encoder=libopus,libmp3lame,aac,flac,pcm_s16le \
      --enable-muxer=ogg,opus,mp3,adts,wav,flac \
      --enable-filter=anull,aresample,aformat,volume,atrim,afade \
      --enable-bsf=aac_adtstoasc \
      --enable-libopus \
      --enable-libmp3lame; then \
        echo '========== FFmpeg configure failed ==========' >&2; \
        if [ -f ffbuild/config.log ]; then \
          tail -n 240 ffbuild/config.log >&2; \
        fi; \
        exit 1; \
    fi

RUN make -j"${NAVIDROME_BUILD_CORES}" V=1 && \
    make install && \
    test -x /usr/local/bin/ffmpeg && \
    test -x /usr/local/bin/ffprobe && \
    llvm-strip --strip-unneeded \
      /usr/local/bin/ffmpeg \
      /usr/local/bin/ffprobe

RUN set -eu; \
    /usr/local/bin/ffmpeg -hide_banner -encoders \
      > /tmp/encoders.txt 2>&1; \
    /usr/local/bin/ffmpeg -hide_banner -decoders \
      > /tmp/decoders.txt 2>&1; \
    /usr/local/bin/ffmpeg -hide_banner -demuxers \
      > /tmp/demuxers.txt 2>&1; \
    /usr/local/bin/ffmpeg -hide_banner -muxers \
      > /tmp/muxers.txt 2>&1; \
    /usr/local/bin/ffmpeg -hide_banner -filters \
      > /tmp/filters.txt 2>&1; \
    \
    require_ffmpeg_entry() { \
      file="$1"; \
      wanted="$2"; \
      kind="$3"; \
      \
      if awk -v wanted="$wanted" ' \
        { \
          count = split($2, names, ","); \
          for (i = 1; i <= count; i++) { \
            if (names[i] == wanted) { \
              found = 1; \
              exit; \
            } \
          } \
        } \
        END { \
          exit(found ? 0 : 1); \
        } \
      ' "$file"; then \
        printf "[ffmpeg-check] %-8s %s: ok\n" \
          "$kind" "$wanted"; \
      else \
        printf "[ffmpeg-check] missing %s: %s\n" \
          "$kind" "$wanted" >&2; \
        printf '%s\n' \
          '========== FFmpeg capability output ==========' >&2; \
        cat "$file" >&2; \
        exit 1; \
      fi; \
    }; \
    \
    for name in \
      libopus \
      libmp3lame \
      aac \
      flac \
      pcm_s16le \
    ; do \
      require_ffmpeg_entry \
        /tmp/encoders.txt \
        "$name" \
        encoder; \
    done; \
    \
    for name in \
      alac \
      aac \
      mp3 \
      flac \
      opus \
      vorbis \
      ape \
      wavpack \
      pcm_s16le \
      pcm_s24le \
      pcm_s32le \
      pcm_f32le \
    ; do \
      require_ffmpeg_entry \
        /tmp/decoders.txt \
        "$name" \
        decoder; \
    done; \
    \
    for name in \
      mov \
      mp3 \
      aac \
      flac \
      wav \
      aiff \
      ogg \
      ape \
      matroska \
      wv \
      s16le \
    ; do \
      require_ffmpeg_entry \
        /tmp/demuxers.txt \
        "$name" \
        demuxer; \
    done; \
    \
    for name in \
      ogg \
      opus \
      mp3 \
      adts \
      wav \
      flac \
    ; do \
      require_ffmpeg_entry \
        /tmp/muxers.txt \
        "$name" \
        muxer; \
    done; \
    \
    for name in \
      anull \
      aresample \
      aformat \
      volume \
      atrim \
      afade \
    ; do \
      require_ffmpeg_entry \
        /tmp/filters.txt \
        "$name" \
        filter; \
    done; \
    \
    rm -f \
      /tmp/encoders.txt \
      /tmp/decoders.txt \
      /tmp/demuxers.txt \
      /tmp/muxers.txt \
      /tmp/filters.txt

RUN set -eu; \
    dd if=/dev/zero \
      of=/tmp/jbs-silence.s16le \
      bs=192000 \
      count=1 \
      status=none; \
    /usr/local/bin/ffmpeg \
      -nostdin \
      -hide_banner \
      -loglevel error \
      -y \
      -f s16le \
      -ar 48000 \
      -ac 2 \
      -i /tmp/jbs-silence.s16le \
      -c:a libmp3lame \
      -b:a 192k \
      -f mp3 \
      /tmp/jbs-test.mp3; \
    /usr/local/bin/ffmpeg \
      -nostdin \
      -hide_banner \
      -loglevel error \
      -y \
      -f s16le \
      -ar 48000 \
      -ac 2 \
      -i /tmp/jbs-silence.s16le \
      -c:a libopus \
      -b:a 128k \
      -f opus \
      /tmp/jbs-test.opus; \
    /usr/local/bin/ffmpeg \
      -nostdin \
      -hide_banner \
      -loglevel error \
      -y \
      -f s16le \
      -ar 48000 \
      -ac 2 \
      -i /tmp/jbs-silence.s16le \
      -c:a aac \
      -b:a 192k \
      -f adts \
      /tmp/jbs-test.aac; \
    /usr/local/bin/ffmpeg \
      -nostdin \
      -hide_banner \
      -loglevel error \
      -y \
      -f s16le \
      -ar 48000 \
      -ac 2 \
      -i /tmp/jbs-silence.s16le \
      -c:a flac \
      -compression_level 5 \
      -f flac \
      /tmp/jbs-test.flac; \
    test -s /tmp/jbs-test.mp3; \
    test -s /tmp/jbs-test.opus; \
    test -s /tmp/jbs-test.aac; \
    test -s /tmp/jbs-test.flac; \
    rm -f \
      /tmp/jbs-silence.s16le \
      /tmp/jbs-test.mp3 \
      /tmp/jbs-test.opus \
      /tmp/jbs-test.aac \
      /tmp/jbs-test.flac

RUN set -eu; \
    ffdeps="$(ldd /usr/local/bin/ffmpeg 2>&1 || true)"; \
    printf '%s\n' "$ffdeps"; \
    case "$ffdeps" in \
      *"not found"*) \
        echo 'FFmpeg has unresolved dynamic dependencies' >&2; \
        exit 1 \
        ;; \
      *libopus.so*|*libmp3lame.so*) \
        echo 'FFmpeg unexpectedly links dynamically to Opus/LAME' >&2; \
        exit 1 \
        ;; \
      *) : ;; \
    esac; \
    file /usr/local/bin/ffmpeg /usr/local/bin/ffprobe

# =========================================================
# Rust unified helper
# =========================================================

FROM ${RUST_IMAGE} AS rust-builder

ARG NAVIDROME_BUILD_CORES
ARG RUST_TARGET_CPU
ARG RUSQLITE_VERSION
ARG WALKDIR_VERSION

RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      build-essential \
      ca-certificates \
      musl-tools \
      pkg-config && \
    rustup target add x86_64-unknown-linux-musl

WORKDIR /build

RUN mkdir -p src && \
    cat > Cargo.toml <<TOML
[package]
name = "jbs-helper"
version = "0.1.0"
edition = "2021"

[dependencies]
rusqlite = { version = "=${RUSQLITE_VERSION}", features = ["bundled"] }
walkdir = "=${WALKDIR_VERSION}"

[profile.release]
opt-level = 3
lto = "fat"
codegen-units = 1
strip = "symbols"
panic = "abort"
TOML

RUN cat > src/main.rs <<'RUST'
use std::env;
use std::fs::File;
use std::io::{Read, Write};
use std::net::{SocketAddr, TcpStream};
use std::path::Path;
use std::process::Command;
use std::time::Duration;

use rusqlite::{Connection, OpenFlags};
use walkdir::WalkDir;

const CHUNK: usize = 1024 * 1024;

fn basename(path: &str) -> &str {
    path.rsplit('/').next().unwrap_or(path)
}

fn is_cmd(name: &str, needle: &str) -> bool {
    name == needle || name.ends_with(needle)
}

fn run_healthcheck() -> i32 {
    let port: u16 = env::var("ND_PORT")
        .unwrap_or_default()
        .parse()
        .unwrap_or(4533);

    let addr = SocketAddr::from(([127, 0, 0, 1], port));
    let timeout = Duration::from_secs(4);

    let mut stream = match TcpStream::connect_timeout(&addr, timeout) {
        Ok(stream) => stream,
        Err(_) => return 1,
    };

    if stream.set_read_timeout(Some(timeout)).is_err()
        || stream.set_write_timeout(Some(timeout)).is_err()
    {
        return 1;
    }

    let req = format!(
        "GET /ping HTTP/1.0\r\nHost: 127.0.0.1:{port}\r\nConnection: close\r\n\r\n"
    );

    if stream.write_all(req.as_bytes()).is_err() {
        return 1;
    }

    let mut response = Vec::with_capacity(1024);
    let mut buf = [0u8; 512];

    while response.len() < 4096 {
        match stream.read(&mut buf) {
            Ok(0) => break,
            Ok(n) => {
                response.extend_from_slice(&buf[..n]);
                if response.windows(4).any(|w| w == b"\r\n\r\n") {
                    break;
                }
            }
            Err(_) => return 1,
        }
    }

    let status_line = response
        .split(|b| *b == b'\n')
        .next()
        .and_then(|line| std::str::from_utf8(line).ok())
        .unwrap_or("")
        .trim_end_matches('\r');

    if status_line.starts_with("HTTP/1.") && status_line.contains(" 200 ") {
        0
    } else {
        1
    }
}

fn db_file_from_nd_dbpath(value: &str) -> Option<String> {
    let mut value = value.trim();

    if let Some(stripped) = value.strip_prefix("file:") {
        value = stripped;
    }

    let file = value.split('?').next().unwrap_or("").trim();

    if file.is_empty() || file == ":memory:" {
        return None;
    }

    Some(file.to_string())
}

fn open_db() -> Result<Option<Connection>, String> {
    let db_path = env::var("ND_DBPATH").unwrap_or_else(|_| {
        "file:/data/navidrome.db?mode=rwc&_journal_mode=WAL&_synchronous=NORMAL".to_string()
    });

    let Some(file) = db_file_from_nd_dbpath(&db_path) else {
        return Ok(None);
    };

    if !Path::new(&file).exists() {
        eprintln!("[sqlite-maint] database does not exist yet: {file}");
        return Ok(None);
    }

    let uri = format!("file:{file}?mode=rw");
    let conn = Connection::open_with_flags(
        &uri,
        OpenFlags::SQLITE_OPEN_READ_WRITE | OpenFlags::SQLITE_OPEN_URI,
    )
    .map_err(|err| format!("open {file}: {err}"))?;

    conn.busy_timeout(Duration::from_secs(120))
        .map_err(|err| format!("busy timeout: {err}"))?;

    Ok(Some(conn))
}

fn run_sql(label: &str, sql: &str) -> i32 {
    let conn = match open_db() {
        Ok(Some(conn)) => conn,
        Ok(None) => return 0,
        Err(err) => {
            eprintln!("[sqlite-maint] {label}: failed: {err}");
            return 1;
        }
    };

    match conn.execute_batch(sql) {
        Ok(_) => {
            eprintln!("[sqlite-maint] {label}: ok");
            0
        }
        Err(err) => {
            eprintln!("[sqlite-maint] {label}: failed: {err}");
            1
        }
    }
}

fn check_pragma(conn: &Connection, pragma: &str) -> Result<(), String> {
    let mut stmt = conn
        .prepare(pragma)
        .map_err(|err| format!("{pragma}: prepare failed: {err}"))?;

    let rows = stmt
        .query_map([], |row| row.get::<_, String>(0))
        .map_err(|err| format!("{pragma}: query failed: {err}"))?;

    let mut problems = Vec::new();

    for row in rows {
        let value = row.map_err(|err| format!("{pragma}: row failed: {err}"))?;

        if !value.eq_ignore_ascii_case("ok") {
            problems.push(value);
        }
    }

    if problems.is_empty() {
        Ok(())
    } else {
        Err(format!("{pragma}: {}", problems.join(" | ")))
    }
}

fn run_sqlite_doctor() -> i32 {
    let conn = match open_db() {
        Ok(Some(conn)) => conn,
        Ok(None) => return 0,
        Err(err) => {
            eprintln!("[sqlite-maint] doctor: failed: {err}");
            return 1;
        }
    };

    for pragma in ["PRAGMA quick_check;", "PRAGMA integrity_check;"] {
        if let Err(err) = check_pragma(&conn, pragma) {
            eprintln!("[sqlite-maint] doctor: failed: {err}");
            return 1;
        }
    }

    eprintln!("[sqlite-maint] doctor: ok");
    0
}

fn run_sqlite_maint(args: &[String]) -> i32 {
    let mode = args.first().map(String::as_str).unwrap_or("startup");

    match mode {
        "startup" => run_sql(
            "startup",
            "
            PRAGMA journal_mode=WAL;
            PRAGMA synchronous=NORMAL;
            PRAGMA foreign_keys=ON;
            PRAGMA temp_store=MEMORY;
            PRAGMA mmap_size=134217728;
            PRAGMA analysis_limit=2000;
            PRAGMA optimize=0x10002;
            PRAGMA wal_checkpoint(PASSIVE);
            PRAGMA shrink_memory;
            ",
        ),
        "idle" => run_sql(
            "idle",
            "
            PRAGMA analysis_limit=1000;
            PRAGMA optimize;
            PRAGMA wal_checkpoint(PASSIVE);
            PRAGMA shrink_memory;
            ",
        ),
        "shutdown" => run_sql(
            "shutdown",
            "
            PRAGMA optimize;
            PRAGMA wal_checkpoint(TRUNCATE);
            PRAGMA shrink_memory;
            ",
        ),
        "doctor" => run_sqlite_doctor(),
        _ => {
            eprintln!(
                "[sqlite-maint] usage: jbs-sqlite-maint [startup|idle|shutdown|doctor]"
            );
            2
        }
    }
}

fn parse_limit_mb(args: &[String]) -> u64 {
    let mut i = 0;

    while i < args.len() {
        if args[i] == "--limit-mb" {
            if let Some(value) = args.get(i + 1) {
                return value.parse::<u64>().unwrap_or(32);
            }
        }

        i += 1;
    }

    env::var("JBS_CACHE_WARM_LIMIT_MB")
        .ok()
        .and_then(|value| value.parse::<u64>().ok())
        .unwrap_or(32)
}

fn read_some(path: &Path, remaining: &mut u64, buf: &mut [u8]) -> u64 {
    if *remaining == 0 {
        return 0;
    }

    let Ok(mut file) = File::open(path) else {
        return 0;
    };

    let before = *remaining;

    loop {
        if *remaining == 0 {
            break;
        }

        let want = (*remaining).min(buf.len() as u64) as usize;

        match file.read(&mut buf[..want]) {
            Ok(0) => break,
            Ok(n) => *remaining = remaining.saturating_sub(n as u64),
            Err(_) => break,
        }
    }

    before.saturating_sub(*remaining)
}

fn warm_fixed_db_files(data: &str, remaining: &mut u64, buf: &mut [u8]) {
    let files = [
        format!("{data}/navidrome.db"),
        format!("{data}/navidrome.db-wal"),
        format!("{data}/navidrome.db-shm"),
    ];

    for file in files {
        if *remaining == 0 {
            break;
        }

        let path = Path::new(&file);
        let read = read_some(path, remaining, buf);

        if read > 0 {
            eprintln!(
                "[cache-warm] warmed {} bytes from {}",
                read,
                path.display()
            );
        }
    }
}

fn run_cache_warm(args: &[String]) -> i32 {
    let mut remaining = parse_limit_mb(args).saturating_mul(1024 * 1024);

    if remaining == 0 {
        return 0;
    }

    let data = env::var("ND_DATAFOLDER").unwrap_or_else(|_| "/data".to_string());
    let cache = env::var("ND_CACHEFOLDER").unwrap_or_else(|_| "/cache".to_string());
    let mut buf = vec![0u8; CHUNK];

    warm_fixed_db_files(&data, &mut remaining, &mut buf);

    let mut seen = 0usize;

    for entry in WalkDir::new(cache)
        .max_depth(3)
        .follow_links(false)
        .into_iter()
        .filter_map(Result::ok)
    {
        if remaining == 0 || seen >= 128 {
            break;
        }

        if entry.file_type().is_file() {
            let read = read_some(entry.path(), &mut remaining, &mut buf);

            if read > 0 {
                eprintln!(
                    "[cache-warm] warmed {} bytes from {}",
                    read,
                    entry.path().display()
                );
            }

            seen += 1;
        }
    }

    eprintln!("[cache-warm] done");
    0
}

fn ffmpeg_path() -> String {
    let configured =
        env::var("ND_FFMPEGPATH").unwrap_or_else(|_| "/usr/local/bin/ffmpeg".to_string());

    let real_candidate = format!("{configured}.real");

    if Path::new(&real_candidate).exists() {
        real_candidate
    } else {
        configured
    }
}

fn capture_ffmpeg(args: &[&str]) -> Result<String, String> {
    let output = Command::new(ffmpeg_path())
        .args(args)
        .output()
        .map_err(|err| err.to_string())?;

    let mut text = String::new();

    text.push_str(&String::from_utf8_lossy(&output.stdout));
    text.push_str(&String::from_utf8_lossy(&output.stderr));

    if output.status.success() {
        Ok(text)
    } else {
        Err(text)
    }
}

fn has_named_entry(output: &str, name: &str) -> bool {
    output.lines().any(|line| {
        line.split_whitespace()
            .nth(1)
            .is_some_and(|entry| entry.split(',').any(|item| item == name))
    })
}

fn require_entries(
    output: &str,
    kind: &str,
    names: &[&str],
    failures: &mut Vec<String>,
) {
    for name in names {
        if !has_named_entry(output, name) {
            failures.push(format!("{kind}:{name}"));
        }
    }
}

fn run_ffmpeg_preflight(args: &[String]) -> i32 {
    let strict = args.iter().any(|arg| arg == "--strict");
    let path = ffmpeg_path();

    let decoders = capture_ffmpeg(&["-hide_banner", "-decoders"]).unwrap_or_default();
    let encoders = capture_ffmpeg(&["-hide_banner", "-encoders"]).unwrap_or_default();
    let demuxers = capture_ffmpeg(&["-hide_banner", "-demuxers"]).unwrap_or_default();
    let muxers = capture_ffmpeg(&["-hide_banner", "-muxers"]).unwrap_or_default();
    let filters = capture_ffmpeg(&["-hide_banner", "-filters"]).unwrap_or_default();

    let mut failures = Vec::new();

    require_entries(
        &decoders,
        "decoder",
        &["alac", "aac", "mp3", "flac", "opus", "vorbis"],
        &mut failures,
    );

    require_entries(
        &encoders,
        "encoder",
        &["libopus", "libmp3lame", "aac", "flac", "pcm_s16le"],
        &mut failures,
    );

    require_entries(
        &demuxers,
        "demuxer",
        &["mov", "mp3", "aac", "flac", "wav", "aiff", "ogg"],
        &mut failures,
    );

    require_entries(
        &muxers,
        "muxer",
        &["ogg", "opus", "mp3", "adts", "wav", "flac"],
        &mut failures,
    );

    require_entries(
        &filters,
        "filter",
        &["aresample", "aformat", "volume"],
        &mut failures,
    );

    if failures.is_empty() {
        eprintln!("[ffmpeg-preflight] ok: {path}");
        return 0;
    }

    eprintln!(
        "[ffmpeg-preflight] missing capabilities from {path}: {}",
        failures.join(", ")
    );

    if strict {
        1
    } else {
        0
    }
}

fn print_usage() -> i32 {
    eprintln!(
        "usage: jbs-helper [healthcheck|sqlite-maint|cache-warm|ffmpeg-preflight] [args...]"
    );

    2
}

fn main() {
    let mut args: Vec<String> = env::args().collect();

    let argv0 = args
        .first()
        .cloned()
        .unwrap_or_else(|| "jbs-helper".to_string());

    let name = basename(&argv0).to_string();

    let code = if is_cmd(&name, "healthcheck") {
        run_healthcheck()
    } else if is_cmd(&name, "jbs-sqlite-maint") {
        let sub_args = args.split_off(1);
        run_sqlite_maint(&sub_args)
    } else if is_cmd(&name, "jbs-cache-warm") {
        let sub_args = args.split_off(1);
        run_cache_warm(&sub_args)
    } else if is_cmd(&name, "jbs-ffmpeg-preflight") {
        let sub_args = args.split_off(1);
        run_ffmpeg_preflight(&sub_args)
    } else {
        let Some(cmd) = args.get(1).cloned() else {
            std::process::exit(print_usage());
        };

        let sub_args: Vec<String> = args.into_iter().skip(2).collect();

        match cmd.as_str() {
            "healthcheck" => run_healthcheck(),
            "sqlite-maint" => run_sqlite_maint(&sub_args),
            "cache-warm" => run_cache_warm(&sub_args),
            "ffmpeg-preflight" => run_ffmpeg_preflight(&sub_args),
            _ => print_usage(),
        }
    };

    std::process::exit(code);
}
